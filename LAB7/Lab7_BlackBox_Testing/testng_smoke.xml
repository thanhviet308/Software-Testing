<!-- testng_smoke.xml: chỉ chạy nhóm smoke -->
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="SmokeSuite">
    <test name="SmokeTests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="dtm.tests"/>
        </packages>
    </test>
</suite>